# LOCAL DEVELOPMENT
# Copy to .env.local or use: docker compose --env-file .env.example up

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=nestuser
DB_PASS=nestpass
DB_NAME=nestdb

# JWT
JWT_SECRET=dev-jwt-secret-not-for-production

# CORS — allow local frontend
CORS_ORIGIN=*

# Frontend API URL (baked at build time)
VITE_API_BASE_URL=http://localhost:3000
